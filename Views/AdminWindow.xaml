<Window
    x:Class="TEMA1_II.Views.AdminWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Title="Admin Panel">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="background.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <Rectangle Fill="#000000" Opacity="0.6"/>

        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Sessions Log"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#E8B923"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"
                       Grid.Row="0"/>

            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Auto">

                <controls:DataGrid
                      x:Name="SessionsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      Background="#1A1A2E"
                      Foreground="White"
                      BorderBrush="#E8B923"
                      BorderThickness="1"
                      RowBackground="#0D0D0D"
                      AlternatingRowBackground="#161616"
                      GridLinesVisibility="Horizontal"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top">

                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150" />
                        <controls:DataGridTextColumn Header="Login Time" Binding="{Binding LoginTime}" Width="200" />
                        <controls:DataGridTextColumn Header="Logout Time" Binding="{Binding LogoutTime}" Width="200" />
                        <controls:DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="120" />
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </ScrollViewer>
        </Grid>

        <Button HorizontalAlignment="Right" 
                VerticalAlignment="Bottom"
                Margin="30"
                Background="#E74C3C" 
                Foreground="White"
                FontWeight="Bold"
                CornerRadius="8"
                Padding="15,10"
                Click="OnLogoutClick">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Exit Admin Panel"/>
                <TextBlock Text="🚪"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>