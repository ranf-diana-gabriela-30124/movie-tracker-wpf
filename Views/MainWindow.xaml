<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TEMA1_II.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TEMA1_II.DataModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TEMA1_II">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <!-- setare imagine de background mainPage -->
        <!-- prima data de la proprietati trebuie sa fie setata content si copy if newer -->
        <Grid.Background>
            <ImageBrush ImageSource="background.jpg"
                        Stretch="UniformToFill"/>
            <!-- umple tot containerul si pastreaza proportiile fotografiei -->
        </Grid.Background>

        <!-- adaugarea unui dreptunghi putin intunecat ca sa am o imagine mai intunecata -->
        <Rectangle Fill="#000000" Opacity="0.45"/>

        <!-- Viewbox - container in dreapta ecranului care contine absolut toate elementele de LogIn -->
        <!-- Daca se schimba dimensiunea Viewboxului, tot din container se va micsora/mari proportional -->
        <Viewbox HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 Margin="0,0,60,0"
                 Stretch="Uniform"
                 MaxWidth="500"
                 MinWidth="320">

            <!-- Cadrul principal de culoare neagra si opacitate 0.6 -->
            <Border
                Padding="40,44"
                CornerRadius="16"
                Width="380">
                <Border.Background>
                    <SolidColorBrush Color="#000000" Opacity="0.6"/>
                </Border.Background>

                <!-- StackPanel - aranjeaza elementele unul sub altul, spatierea e controlata prin margin la fiecare element -->
                <StackPanel Spacing="0" Width="300">

                    <!-- Titlu -->
                    <TextBlock Text="🎬 CinemaGlow"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#E8B923"
                               Margin="0,0,0,6"/>

                    <!-- Subtitlu -->
                    <TextBlock Text="Sign in and add to your watchlist the movie you want to see next!"
                               Foreground="#AAAAAA"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Margin="0,0,0,32"/>

                    <!-- chenarul afisat cu eroarea   -->
                    <Border x:Name="ErrorBar"
                            Visibility="Collapsed"
                            Background="#3D1515"
                            BorderBrush="#C0392B"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,7"
                            Margin="0,0,0,12">

                        <Grid>
                            <!-- imparte in doua coloane ca sa fie simetric -->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- prima coloana - textul propriu-zis -->
                            <TextBlock Grid.Column="0"
                                       Text="Incorrect email or password."
                                       Foreground="#FF6B6B"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap"/>

                            <!-- a doua coloana - butonul de X - de iesire din errorBar -->
                            <Button Grid.Column="1"
                                    Content="✕"
                                    FontSize="10"
                                    Foreground="#FF6B6B"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,2"
                                    VerticalAlignment="Center"
                                    Click="CloseErrorBar_Click"/>
                        </Grid>
                    </Border>

                    <!-- Partea de username si password -->
                    <TextBlock Text="Email"
                               FontSize="14"
                               Foreground="#AAAAAA"
                               Margin="0,0,0,6"/>

                    <TextBox x:Name="EmailBox"
                             PlaceholderText="Enter your email"
                             Margin="0,0,0,20"
                             Background="#1E1E2E"
                             Foreground="White"
                             BorderBrush="#E8B923"
                             BorderThickness="0,0,0,1"
                             FontSize="14"
                             Padding="8,10"/>

                    <TextBlock Text="Password"
                               FontSize="14"
                               Foreground="#AAAAAA"
                               Margin="0,0,0,6"/>

                    <PasswordBox x:Name="PasswordBox"
                                 PlaceholderText="Enter your password"
                                 Margin="0,0,0,28"
                                 Background="#1E1E2E"
                                 Foreground="White"
                                 BorderBrush="#E8B923"
                                 BorderThickness="0,0,0,1"
                                 FontSize="14"
                                 Padding="8,10"/>

                    <!-- Butonul de SignIn-->
                    <Button x:Name="SignInButton"
                            Content="Sign in"
                            HorizontalAlignment="Stretch"
                            Click="ClickOnSignInButton"
                            Background="#E8B923"
                            Foreground="#0D0D0D"
                            FontWeight="SemiBold"
                            FontSize="14"
                            CornerRadius="8"
                            Padding="0,14"/>

                    <Button Content="Don't have an account? Create one"
        Background="Transparent"
        Foreground="#E8B923"
        BorderThickness="0"
        HorizontalAlignment="Center"
        Margin="0,16,0,0"
        Click="GoToRegister_Click"/>

                </StackPanel>
            </Border>
        </Viewbox>
    </Grid>
</Window>